# See https://docs.docker.com/engine/reference/builder/#dockerignore-file for more about ignoring files.

# Ignore git directory.
/.git/
/.gitignore

# Ignore development files
/.devcontainer

# Ignore CI service files.
/.github

# Ignore Kamal files
/.kamal

# Ignore Docker-related files
/.dockerignore
/Dockerfile*

# Vibe coding
/.claude
/AGENTS.md
/CLAUDE.md
/memory

# Docs
/docs

# Below contents are synced from .gitignore

/.yardoc
/_yardoc/
/doc/
/pkg/
/spec/reports/
.DS_Store

# IDE and Editor specific
/.idea
/.cursor
/.ruby-lsp
/.vscode

# Ignore bundler config.
/.bundle

# MCP temp files
/.playwright-mcp

# Playwright (optional E2E)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright.config.ts
/bin/e2e

# Ignore node_modules
/node_modules

# Tests (not needed in production image)
/test/

# Simple-cov
/coverage/

# Ignore pid files, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore socket files, but keep the directory.
/tmp/sockets/*
!/tmp/sockets/
!/tmp/sockets/.keep

# Ignore all environment files.
/.env*
!/.env*.erb
!/.env*.sample

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep
/state/

# Ignore SQLite database files.
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore all default key files.
/config/master.key
/config/credentials/*.key
/config/credentials.yml.enc
/config/credentials/*.yml.enc

# Ignore local settings files
/config/settings.local.yml
/config/settings/*.local.yml
/config/environments/*.local.yml

# Ignore runtime override files; mount config.d at runtime instead of baking local overrides into the image.
/config.d/*
!/config.d/.gitignore
!/config.d/.keep

# Ignore environment specified config files
/config/deploy.yml
/compose.yaml

# Assets pipeline
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets
