<% content_for :title, "Core Matrix" %>

<main class="mx-auto flex min-h-screen max-w-3xl flex-col justify-center gap-6 px-6 py-16">
  <header class="space-y-3">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Cybros Runtime</p>
    <h1 class="text-4xl font-semibold tracking-tight text-slate-950">Core Matrix</h1>
    <p class="max-w-2xl text-base leading-7 text-slate-600">
      Control plane online. Use the agent, executor, and app APIs to drive runtime workflows.
    </p>
  </header>

  <section class="rounded-2xl border border-slate-200 bg-white/80 p-6 shadow-sm">
    <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Available Surfaces</h2>
    <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-700">
      <li><strong class="text-slate-950">Agent API</strong> for runtime registration, polling, and report delivery.</li>
      <li><strong class="text-slate-950">Executor API</strong> for command, process, and attachment resources.</li>
      <li><strong class="text-slate-950">App API</strong> for diagnostics, supervision, exports, and conversation state.</li>
    </ul>
  </section>
</main>
