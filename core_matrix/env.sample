# =============================================================================
# Cybros Environment Variables
# =============================================================================
#
# This file documents all environment variables used by Cybros.
# Copy this file to .env and fill in the values.
#
# ⚠️ NEVER commit .env to version control!
#
# Quick setup:
#   cp env.sample .env
#   # Then edit .env and fill in the values below
#
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (Required for Docker/Production)
# -----------------------------------------------------------------------------
# PostgreSQL password. Used by docker-compose.yaml.
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Rails Secret Keys (Required for Production)
# -----------------------------------------------------------------------------
# SECRET_KEY_BASE is used for all MessageVerifiers in Rails, including cookies.
# Generate: bundle exec rails secret
SECRET_KEY_BASE=

# -----------------------------------------------------------------------------
# Active Record Encryption (Required for Production)
# -----------------------------------------------------------------------------
# These keys encrypt sensitive data (e.g., API keys stored in database).
# Generate all three keys:
#   bundle exec rails db:encryption:init
#
# Then copy the output into these variables.
ACTIVE_RECORD_ENCRYPTION__PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION__DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION__KEY_DERIVATION_SALT=

# -----------------------------------------------------------------------------
# Optional: Development Overrides
# -----------------------------------------------------------------------------
# Override Rails environment (default: development)
# RAILS_ENV=development

# Override Rails port (default: 3000)
# RAILS_PORT=3000

# Override database connection string base
# Host-side Rails commands load `.env*` via dotenv-rails.
# Example for Ubuntu host Rails connecting to Docker PostgreSQL 18 on localhost:
# RAILS_DB_URL_BASE=postgresql://postgres:postgres@localhost:5432

# -----------------------------------------------------------------------------
# Optional: SSL Configuration
# -----------------------------------------------------------------------------
# Force SSL in production (default: true in production)
# RAILS_FORCE_SSL=true

# Assume SSL termination by reverse proxy (default: true in production)
# RAILS_ASSUME_SSL=true

# -----------------------------------------------------------------------------
# Optional: Log Level
# -----------------------------------------------------------------------------
# Set log level (default: info in production, debug in development)
# RAILS_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Optional: Performance Tuning
# -----------------------------------------------------------------------------
# Max threads per Puma worker (default: 8)
# RAILS_MAX_THREADS=8

# Number of Puma workers in production (default: 2). Outside production, Puma
# stays in single-process mode unless you opt into cluster mode explicitly.
# RAILS_WEB_CONCURRENCY=2

# Shared database connection pool override.
# Leave unset to use the role-specific defaults below; set this only if you
# want the same pool size applied everywhere.
# RAILS_DB_POOL=40
#
# Primary / cache pool default: 16 (or RAILS_MAX_THREADS if higher)
# RAILS_PRIMARY_DB_POOL=16
#
# Queue pool default: 40 to cover the widened Solid Queue thread budget
# RAILS_QUEUE_DB_POOL=40
#
# Cable pool default: 16
# RAILS_CABLE_DB_POOL=16

# Run SolidQueue inside Puma process (default: false)
# SOLID_QUEUE_IN_PUMA=true

# -----------------------------------------------------------------------------
# Optional: Solid Queue Reference Topology (8 CPU / 16GB baseline)
# -----------------------------------------------------------------------------
# These values match the checked-in `config/queue.yml` defaults and are a good
# starting point for a single CoreMatrix host intended to coordinate up to
# eight connected Fenix runtimes on an 8-core / 16GB machine. Actual headroom
# still depends on workload mix, provider latency, and tool-call intensity.
#
# Set these in your deployment environment if you want the baseline explicitly
# visible instead of relying on the defaults baked into `config/queue.yml`.
#
# Provider LLM queues are isolated by provider handle.
# SQ_THREADS_LLM_CODEX_SUBSCRIPTION=4
# SQ_PROCESSES_LLM_CODEX_SUBSCRIPTION=1
# SQ_THREADS_LLM_OPENAI=6
# SQ_PROCESSES_LLM_OPENAI=1
# SQ_THREADS_LLM_OPENROUTER=4
# SQ_PROCESSES_LLM_OPENROUTER=1
# SQ_THREADS_LLM_DEV=4
# SQ_PROCESSES_LLM_DEV=1
# SQ_THREADS_LLM_LOCAL=2
# SQ_PROCESSES_LLM_LOCAL=1
#
# Tool calls can also be wide, but they stay in their own shared queue.
# SQ_THREADS_TOOL_CALLS=12
# SQ_PROCESSES_TOOL_CALLS=1
#
# Workflow coordination should stay moderate so it does not starve hot queues.
# SQ_THREADS_WORKFLOW_DEFAULT=4
# SQ_PROCESSES_WORKFLOW_DEFAULT=1
# SQ_THREADS_WORKFLOW_RESUME=2
# SQ_PROCESSES_WORKFLOW_RESUME=1
#
# Maintenance should stay narrow.
# SQ_THREADS_MAINTENANCE=1
# SQ_PROCESSES_MAINTENANCE=1

# -----------------------------------------------------------------------------
# Optional: Data Retention
# -----------------------------------------------------------------------------
# Daily maintenance prunes bounded audit rows and closed supervision artifacts.
#
# Batch size per delete loop. Keep this modest if you expect very large tables.
# DATA_RETENTION_BATCH_SIZE=500
#
# Retain detailed usage events and completed/failed/rejected conversation
# control requests for this many days.
# DATA_RETENTION_BOUNDED_AUDIT_DAYS=30
#
# Retain closed supervision sessions and their snapshots/messages for this many
# days before the maintenance job removes them.
# DATA_RETENTION_SUPERVISION_CLOSED_DAYS=7
