#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ROUTES_FILE="${NEXUS_DEV_PROXY_ROUTES_FILE:-$ROOT_DIR/tmp/dev-proxy/routes.caddy}"

mkdir -p "$(dirname "$ROUTES_FILE")"
if [ ! -s "$ROUTES_FILE" ]; then
  printf "# nexus dev proxy routes\n" > "$ROUTES_FILE"
fi

exec caddy run --config "$ROOT_DIR/config/caddy/Caddyfile" --adapter caddyfile
