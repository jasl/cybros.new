#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
versions_file="${script_dir}/../../../images/nexus/versions.env"

# shellcheck disable=SC1090
source "${versions_file}"

lookup_path="${NEXUS_HOST_CHECK_PATH:-$PATH}"
host_os="${NEXUS_HOST_CHECK_OS:-$(uname -s)}"
browser_path="${PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH:-}"
host_check_runtime_root="${NEXUS_HOST_CHECK_RUNTIME_ROOT:-}"
created_runtime_root=""

declare -a missing=()
declare -a warnings=()
resolved_command_path=""

find_command() {
  local command_name="$1"
  PATH="${lookup_path}" command -v "${command_name}" 2>/dev/null || true
}

command_output() {
  local command_path="$1"
  shift

  "${command_path}" "$@" 2>/dev/null | head -n 1 | tr -d '\r'
}

require_command() {
  local command_name="$1"
  local message="$2"
  local command_path

  command_path="$(find_command "${command_name}")"
  if [[ -z "${command_path}" ]]; then
    missing+=("${message}")
    return 1
  fi

  resolved_command_path="${command_path}"
}

require_version_prefix() {
  local command_name="$1"
  local expected_prefix="$2"
  local message="$3"
  shift 3

  require_command "${command_name}" "${message}" || return 0

  local actual
  actual="$(command_output "${resolved_command_path}" "$@")"
  [[ "${actual}" == "${expected_prefix}"* ]] || missing+=("${message} (found '${actual}')")
}

require_version_value() {
  local command_name="$1"
  local expected_value="$2"
  local message="$3"
  shift 3

  require_command "${command_name}" "${message}" || return 0

  local actual
  actual="$(command_output "${resolved_command_path}" "$@")"
  [[ "${actual}" == "${expected_value}" ]] || missing+=("${message} (found '${actual}')")
}

require_last_field_value() {
  local command_name="$1"
  local expected_value="$2"
  local message="$3"
  shift 3

  require_command "${command_name}" "${message}" || return 0

  local actual
  actual="$(command_output "${resolved_command_path}" "$@" | awk '{print $NF}')"
  [[ "${actual}" == "${expected_value}" ]] || missing+=("${message} (found '${actual}')")
}

case "${host_os}" in
  Darwin)
    warnings+=("macOS is a best-effort bare-metal target; Docker on images/nexus remains the default deployment path.")
    ;;
  Linux)
    if [[ -r /etc/os-release ]]; then
      # shellcheck disable=SC1091
      source /etc/os-release
      if [[ "${ID:-}" != "ubuntu" || "${VERSION_ID:-}" != "24.04" ]]; then
        warnings+=("Ubuntu 24.04 is the canonical bare-metal target; continuing with a best-effort check on ${PRETTY_NAME:-Linux}.")
      fi
    fi
    ;;
  *)
    echo "nexus host check: unsupported host OS '${host_os}'. Supported hosts are Linux and macOS." >&2
    exit 1
    ;;
esac

require_version_prefix "ruby" "ruby ${RUBY_VERSION}" "ruby ${RUBY_VERSION} is required" --version
require_last_field_value "bundle" "${BUNDLER_VERSION}" "bundler ${BUNDLER_VERSION} is required" --version
require_version_value "node" "v${NODE_VERSION}" "node ${NODE_VERSION} is required" --version
require_version_value "npm" "${NPM_VERSION}" "npm ${NPM_VERSION} is required" --version
require_command "corepack" "corepack is required" >/dev/null || true
require_version_value "pnpm" "${PNPM_VERSION}" "pnpm ${PNPM_VERSION} is required" --version
require_version_prefix "uv" "uv ${UV_VERSION}" "uv ${UV_VERSION} is required" --version

for tool_name in git curl jq rg fd sqlite3; do
  require_command "${tool_name}" "${tool_name} is required" >/dev/null || true
done

browser_probe_output() {
  local node_command
  local -a probe_environment

  node_command="$(find_command "node")"
  [[ -n "${node_command}" ]] || return 1

  probe_environment=("PATH=${lookup_path}")
  if [[ -n "${PLAYWRIGHT_BROWSERS_PATH:-}" ]]; then
    probe_environment+=("PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH}")
  fi
  if [[ -n "${browser_path}" ]]; then
    probe_environment+=("PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=${browser_path}")
  fi

  env "${probe_environment[@]}" \
    "${node_command}" "${script_dir}/../scripts/browser/session_host.mjs" \
    2>/dev/null <<'JSON' | head -n 1 | tr -d '\r'
{"command":"probe","arguments":{}}
JSON
}

verify_optional_browser_automation() {
  local playwright_command
  local playwright_version
  local playwright_version_warning=""
  local probe_output
  local probe_available
  local probe_reason
  local probe_message

  playwright_command="$(find_command "playwright")"
  if [[ -n "${playwright_command}" ]]; then
    playwright_version="$(command_output "${playwright_command}" --version | awk '{print $NF}' || true)"
    if [[ "${playwright_version}" != "${PLAYWRIGHT_VERSION}" ]]; then
      playwright_version_warning="playwright ${PLAYWRIGHT_VERSION} is expected (found '${playwright_version}')"
    fi
  fi

  probe_output="$(browser_probe_output || true)"
  probe_available="$(jq -r '.payload.available // false' <<<"${probe_output}" 2>/dev/null || true)"
  probe_reason="$(jq -r '.payload.reason // empty' <<<"${probe_output}" 2>/dev/null || true)"
  probe_message="$(jq -r '.payload.message // empty' <<<"${probe_output}" 2>/dev/null || true)"

  if [[ "${probe_available}" != "true" ]]; then
    case "${probe_reason}" in
      playwright_missing)
        warnings+=("browser automation disabled: ${probe_message:-playwright ${PLAYWRIGHT_VERSION} is not installed}")
        ;;
      browser_executable_missing)
        warnings+=("browser automation disabled: ${probe_message:-install Chromium on the host, run 'playwright install chromium', or set PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH}")
        ;;
      node_missing)
        warnings+=("browser automation disabled: ${probe_message:-node is not available for the browser capability probe}")
        ;;
      *)
        warnings+=("browser automation disabled: ${probe_message:-browser capability probe failed}")
        ;;
    esac
  fi

  if [[ -n "${playwright_version_warning}" ]]; then
    warnings+=("browser automation dependency drift: ${playwright_version_warning}")
  fi
}

cleanup() {
  if [[ -n "${created_runtime_root}" ]]; then
    rm -rf "${created_runtime_root}"
  fi
}

trap cleanup EXIT

verify_managed_python_runtime() {
  local runtime_root="${host_check_runtime_root}"
  if [[ -z "${runtime_root}" ]]; then
    runtime_root="$(mktemp -d "${TMPDIR:-/tmp}/nexus-host-check.XXXXXX")"
    created_runtime_root="${runtime_root}"
  fi

  local python_root="${runtime_root}/python"
  local install_root="${runtime_root}/toolchains/python"
  mkdir -p "${runtime_root}" "${install_root}"

  if ! PATH="${lookup_path}" UV_PYTHON_INSTALL_DIR="${install_root}" uv venv --python "${PYTHON_MAJOR_MINOR}" --seed "${python_root}" >/dev/null 2>&1; then
    missing+=("uv must be able to provision Python ${PYTHON_MAJOR_MINOR}.x under NEXUS_HOME_ROOT/python")
    return
  fi

  local python_output
  python_output="$("${python_root}/bin/python" --version 2>/dev/null | head -n 1 | tr -d '\r')"
  [[ "${python_output}" == "Python ${PYTHON_MAJOR_MINOR}"* ]] || \
    missing+=("managed python runtime is not Python ${PYTHON_MAJOR_MINOR}.x (found '${python_output}')")

  local pip_path="${python_root}/bin/pip"
  [[ -x "${pip_path}" ]] || missing+=("managed pip command is missing from NEXUS_HOME_ROOT/python/bin")
}

verify_managed_python_runtime
verify_optional_browser_automation

if (( ${#missing[@]} > 0 )); then
  {
    echo "nexus host check: missing prerequisites:"
    printf ' - %s\n' "${missing[@]}"
  } >&2
  exit 1
fi

if (( ${#warnings[@]} > 0 )); then
  printf 'nexus host check: warning: %s\n' "${warnings[@]}"
fi

echo "nexus host check: host contract satisfied"
