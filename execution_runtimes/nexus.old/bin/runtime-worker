#!/usr/bin/env bash
set -euo pipefail

jobs_pid=""
standalone_solid_queue=false

case "${STANDALONE_SOLID_QUEUE:-}" in
  true|1)
    standalone_solid_queue=true
    ;;
esac

cleanup() {
  if [[ "${standalone_solid_queue}" == "true" && -n "${jobs_pid}" ]]; then
    kill -TERM "${jobs_pid}" 2>/dev/null || true
    wait "${jobs_pid}" 2>/dev/null || true
  fi
}

trap cleanup EXIT INT TERM

if [[ "${standalone_solid_queue}" == "true" ]]; then
  ./bin/jobs start &
  jobs_pid="$!"
fi

exec ./bin/rails runtime:control_loop_forever "$@"
