# =============================================================================
# Nexus Environment Variables
# =============================================================================
#
# This file documents the runtime environment surface for local Docker runs and
# bare-metal deployments.
#
# Docker default:
#
#   cp execution_runtimes/nexus/env.sample execution_runtimes/nexus/.env
#   docker build -f images/nexus/Dockerfile -t nexus-local .
#   docker build --build-arg NEXUS_BASE_IMAGE=nexus-local:latest -f execution_runtimes/nexus/Dockerfile -t nexus-local execution_runtimes/nexus
#   docker run --env-file ./execution_runtimes/nexus/.env -p 3101:80 nexus-local
#
# Multi-arch release:
#
#   docker buildx build --platform linux/amd64,linux/arm64 --push \
#     -f images/nexus/Dockerfile -t ghcr.io/your-org/nexus-base:latest .
#   docker buildx build --platform linux/amd64,linux/arm64 --push \
#     --build-arg NEXUS_BASE_IMAGE=ghcr.io/your-org/nexus-base:latest \
#     -f execution_runtimes/nexus/Dockerfile -t ghcr.io/your-org/nexus-runtime:latest execution_runtimes/nexus
#
# The NEXUS_BASE_IMAGE used for release must already be a multi-arch image.
#
# Bare metal:
#
#   bin/check-runtime-host
#
# Satisfy any missing prerequisites the validator reports, then export the same
# environment variables (or provide them through Rails credentials).
#
# If `NEXUS_HOME_ROOT` is unset, bare-metal boots default to `~/.nexus` and
# provision a uv-managed Python runtime under `~/.nexus/python`, exposing
# `python` and `pip` from that managed runtime inside the agent process.
#
# Docker and Compose runs default to `RAILS_ENV=production`. Bare-metal boots
# keep the host default unless you override `RAILS_ENV` explicitly.
#
# NEVER commit `.env` or any other populated env file.

# -----------------------------------------------------------------------------
# Runtime Identity and Core Matrix Pairing
# -----------------------------------------------------------------------------
NEXUS_PUBLIC_BASE_URL=http://localhost:3101
CORE_MATRIX_BASE_URL=http://core-matrix:3000
CORE_MATRIX_EXECUTION_RUNTIME_CONNECTION_CREDENTIAL=

# Optional bare-metal override when Chromium is not on PATH.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Optional writable runtime root. Defaults to `~/.nexus` on bare metal.
# NEXUS_HOME_ROOT=/Users/you/.nexus

# Fixed-port dev proxy paths remain app-local runtime settings.
NEXUS_DEV_PROXY_PORT=3310
NEXUS_DEV_PROXY_ROUTES_FILE=/rails/tmp/dev-proxy/routes.caddy

# -----------------------------------------------------------------------------
# Rails Secret Keys
# -----------------------------------------------------------------------------
# Required unless Rails credentials already provide `secret_key_base`.
# Generate with: bundle exec rails secret
SECRET_KEY_BASE=

# -----------------------------------------------------------------------------
# Active Record Encryption
# -----------------------------------------------------------------------------
# Required unless Rails credentials already provide:
#   active_record_encryption.primary_key
#   active_record_encryption.deterministic_key
#   active_record_encryption.key_derivation_salt
#
# Generate with:
#   bundle exec rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION__PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION__DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION__KEY_DERIVATION_SALT=

# -----------------------------------------------------------------------------
# Optional Runtime Overrides
# -----------------------------------------------------------------------------
# Uncomment only if you want the env file to state the container default
# explicitly, or if you want to force host-side production boots.
# RAILS_ENV=production
# RAILS_PORT=3000
# RAILS_FORCE_SSL=true
# RAILS_ASSUME_SSL=true
# RAILS_LOG_LEVEL=info
# STANDALONE_SOLID_QUEUE=true
