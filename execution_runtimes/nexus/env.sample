# =============================================================================
# Nexus Runtime Gem Container Environment
# =============================================================================
#
# This file documents the environment surface for the packaged gem runtime and
# its container image.
#
# Local build:
#
#   cp execution_runtimes/nexus/env.sample execution_runtimes/nexus/.env
#   docker build -f images/nexus/Dockerfile -t nexus-base-local .
#   docker build \
#     --build-arg NEXUS_BASE_IMAGE=nexus-base-local \
#     -f execution_runtimes/nexus/Dockerfile \
#     -t nexus-runtime-local \
#     execution_runtimes/nexus
#   docker run --rm --env-file execution_runtimes/nexus/.env -p 3101:3101 nexus-runtime-local
#
# Multi-arch release:
#
#   docker buildx build --platform linux/amd64,linux/arm64 --push \
#     -f images/nexus/Dockerfile -t ghcr.io/your-org/nexus-base:latest .
#   docker buildx build --platform linux/amd64,linux/arm64 --push \
#     --build-arg NEXUS_BASE_IMAGE=ghcr.io/your-org/nexus-base:latest \
#     -f execution_runtimes/nexus/Dockerfile \
#     -t ghcr.io/your-org/nexus-runtime:latest \
#     execution_runtimes/nexus
#
# The NEXUS_BASE_IMAGE used for release must already be a multi-arch image.
#
# NEVER commit `.env` or any other populated env file.

# -----------------------------------------------------------------------------
# CoreMatrix pairing
# -----------------------------------------------------------------------------
CORE_MATRIX_BASE_URL=http://host.docker.internal:3000
NEXUS_ONBOARDING_TOKEN=
CORE_MATRIX_EXECUTION_RUNTIME_CONNECTION_CREDENTIAL=

# -----------------------------------------------------------------------------
# Runtime networking and local state
# -----------------------------------------------------------------------------
NEXUS_PUBLIC_BASE_URL=http://localhost:3101
NEXUS_HTTP_BIND=0.0.0.0
NEXUS_HTTP_PORT=3101
NEXUS_HOME_ROOT=/var/lib/nexus

# Optional override when Chromium is not discoverable on PATH.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# Optional Node override for the browser host.
# NEXUS_NODE_COMMAND=node

# Optional websocket/poll tuning.
# REALTIME_TIMEOUT_SECONDS=5
