# =============================================================================
# Fenix Environment Variables
# =============================================================================
#
# This file documents the environment surface for container deployments.
# Copy it to `.env` or another private file and pass it with `--env-file`.
#
#   cp env.sample .env
#   docker run --env-file ./.env <image_name>
#
# Docker Compose can use the same file through `env_file: ./.env`.
#
# ⚠️ NEVER commit `.env` or any other populated env file.
#
# Bare-metal and development deployments can use either:
# - ENV variables from this file, or
# - Rails credentials (`config/master.key` + `config/credentials.yml.enc`)
#
# If Rails credentials are present, `Fenix` will fall back to them when the
# corresponding ENV variable is blank.
#
# Populate credentials with:
#
#   bin/rails credentials:edit
#
# Then provide these keys:
#
#   secret_key_base: ...
#   active_record_encryption:
#     primary_key: ...
#     deterministic_key: ...
#     key_derivation_salt: ...
#
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime Identity and Core Matrix Pairing
# -----------------------------------------------------------------------------
# Public base URL exposed by this runtime.
FENIX_PUBLIC_BASE_URL=http://localhost:3101

# Core Matrix control plane base URL.
CORE_MATRIX_BASE_URL=http://core-matrix:3000

# Core Matrix machine credential for this runtime.
CORE_MATRIX_MACHINE_CREDENTIAL=

# Playwright browser install root inside the container.
PLAYWRIGHT_BROWSERS_PATH=/rails/.playwright

# Fixed-port dev proxy for browser-verified preview services.
FENIX_DEV_PROXY_PORT=3310
FENIX_DEV_PROXY_ROUTES_FILE=/rails/tmp/dev-proxy/routes.caddy

# -----------------------------------------------------------------------------
# Rails Secret Keys
# -----------------------------------------------------------------------------
# Required unless Rails credentials already provide `secret_key_base`.
# Generate with: bundle exec rails secret
SECRET_KEY_BASE=

# -----------------------------------------------------------------------------
# Active Record Encryption
# -----------------------------------------------------------------------------
# Required unless Rails credentials already provide:
#   active_record_encryption.primary_key
#   active_record_encryption.deterministic_key
#   active_record_encryption.key_derivation_salt
#
# Generate with:
#   bundle exec rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION__PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION__DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION__KEY_DERIVATION_SALT=

# -----------------------------------------------------------------------------
# Optional: General Runtime Overrides
# -----------------------------------------------------------------------------
# RAILS_ENV=production
# RAILS_PORT=3000
# RAILS_FORCE_SSL=true
# RAILS_ASSUME_SSL=true
# RAILS_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Optional: Web Runtime Tuning
# -----------------------------------------------------------------------------
# The checked-in Puma defaults stay conservative. These overrides are the
# recommended floor for a 4-core / 8 GB host that serves real traffic.
#
# RAILS_MAX_THREADS=5
# RAILS_WEB_CONCURRENCY=2

# Leave this unset for the default single-service deployment, where Puma also
# supervises Solid Queue. Set it only when you want to run `bin/jobs start`
# as a separate process.
# STANDALONE_SOLID_QUEUE=true

# -----------------------------------------------------------------------------
# Optional: Runtime Topology (4-core / 8 GB floor)
# -----------------------------------------------------------------------------
# `config/database.yml` and `config/queue.yml` are the source of truth for the
# baked-in Fenix baseline. Leave these commented unless the host sizing or the
# runtime workload mix needs a different shape:
# - FENIX_PRIMARY_DB_POOL=8
# - FENIX_QUEUE_DB_POOL=16
# - SQ_THREADS_PREPARE=3
# - SQ_THREADS_PURE_TOOLS=8
# - SQ_THREADS_PROCESS_TOOLS=3
# - SQ_THREADS_RUNTIME_CONTROL=2
# - SQ_THREADS_MAINTENANCE=1
#
# Override them here only when you need to deviate from the baked-in baseline.
#
# FENIX_PRIMARY_DB_POOL=8
# FENIX_QUEUE_DB_POOL=16
# SQ_THREADS_PREPARE=3
# SQ_PROCESSES_PREPARE=1
# SQ_THREADS_PURE_TOOLS=8
# SQ_PROCESSES_PURE_TOOLS=1
# SQ_THREADS_PROCESS_TOOLS=3
# SQ_PROCESSES_PROCESS_TOOLS=1
# SQ_THREADS_RUNTIME_CONTROL=2
# SQ_PROCESSES_RUNTIME_CONTROL=1
# SQ_THREADS_MAINTENANCE=1
# SQ_PROCESSES_MAINTENANCE=1

# -----------------------------------------------------------------------------
# Optional: Scale-Up Hint (16-core production host)
# -----------------------------------------------------------------------------
# Start by widening processes before pushing thread counts much higher:
#
# RAILS_WEB_CONCURRENCY=4
# FENIX_PRIMARY_DB_POOL=10
# FENIX_QUEUE_DB_POOL=24
# SQ_PROCESSES_PURE_TOOLS=2
# SQ_PROCESSES_PROCESS_TOOLS=2
# SQ_PROCESSES_RUNTIME_CONTROL=2
