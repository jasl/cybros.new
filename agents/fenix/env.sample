# =============================================================================
# Fenix Environment Variables
# =============================================================================
#
# This file documents the lightweight agent service surface for local Docker
# runs and bare-metal deployments.
#
# Docker default:
#
#   cp env.sample .env
#   docker build -f agents/fenix/Dockerfile -t fenix-local agents/fenix
#   docker run --env-file ./.env -p 3101:80 fenix-local
#
# Docker and Compose runs default to `RAILS_ENV=production`. Bare-metal boots
# keep the host default unless you override `RAILS_ENV` explicitly.
#
# NEVER commit `.env` or any other populated env file.

# -----------------------------------------------------------------------------
# Runtime Identity and Core Matrix Pairing
# -----------------------------------------------------------------------------
FENIX_PUBLIC_BASE_URL=http://localhost:3101
CORE_MATRIX_BASE_URL=http://core-matrix:3000
CORE_MATRIX_AGENT_CONNECTION_CREDENTIAL=

# -----------------------------------------------------------------------------
# Rails Secret Keys
# -----------------------------------------------------------------------------
# Required unless Rails credentials already provide `secret_key_base`.
# Generate with: bundle exec rails secret
SECRET_KEY_BASE=

# -----------------------------------------------------------------------------
# Active Record Encryption
# -----------------------------------------------------------------------------
# Required unless Rails credentials already provide:
#   active_record_encryption.primary_key
#   active_record_encryption.deterministic_key
#   active_record_encryption.key_derivation_salt
#
# Generate with:
#   bundle exec rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION__PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION__DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION__KEY_DERIVATION_SALT=

# -----------------------------------------------------------------------------
# Optional Runtime Overrides
# -----------------------------------------------------------------------------
# Uncomment only if you want the env file to state the container default
# explicitly, or if you want to force host-side production boots.
# RAILS_ENV=production
# RAILS_PORT=3000
# RAILS_FORCE_SSL=true
# RAILS_ASSUME_SSL=true
# RAILS_LOG_LEVEL=info
# STANDALONE_SOLID_QUEUE=true
