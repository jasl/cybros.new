#!/usr/bin/env bash
set -euo pipefail

jobs_pid=""

cleanup() {
  if [[ -n "${jobs_pid}" ]]; then
    kill -TERM "${jobs_pid}" 2>/dev/null || true
    wait "${jobs_pid}" 2>/dev/null || true
  fi
}

trap cleanup EXIT INT TERM

./bin/jobs start &
jobs_pid="$!"

./bin/rails runtime:control_loop_forever "$@"
